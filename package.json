{
  "name": "sec0-oss-workspace",
  "private": true,
  "description": "Public OSS workspace for the Sec0 SDK",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=sec0-sdk",
    "typecheck": "npm run typecheck --workspace=sec0-sdk",
    "test": "npm run test --workspace=sec0-sdk",
    "lint": "npm run lint --workspace=sec0-sdk",
    "pack:check": "npm run pack:dry-run --workspace=sec0-sdk",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run pack:check"
  }
}
