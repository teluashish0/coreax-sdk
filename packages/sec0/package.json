{
  "name": "sec0",
  "private": false,
  "version": "0.1.0",
  "description": "Reserved placeholder package for the Sec0 npm namespace.",
  "license": "Apache-2.0",
  "author": "WormAI, Inc.",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run --passWithNoTests",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "20.19.23",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
