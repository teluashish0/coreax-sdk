{
  "name": "sec0-sdk",
  "version": "0.1.0",
  "description": "Minimal public starter package for the Sec0 SDK.",
  "license": "Apache-2.0",
  "author": "WormAI, Inc.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
